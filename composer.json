{
  "name": "yugo/panelis-blog",
  "description": "Manage blog posts, categories, tags, and editorial content.",
  "license": "MIT",
  "keywords": [
    "panelis"
  ],
  "require": {
    "filament/filament": "^5.0",
    "laravel/framework": "^13.0"
  },
  "autoload": {
    "psr-4": {
      "Panelis\\Blog\\": "src/",
      "Panelis\\Blog\\Database\\Factories\\": "database/factories/",
      "Panelis\\Blog\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Panelis\\Blog\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Panelis\\Blog\\Providers\\BlogServiceProvider"
      ]
    },
    "plugins": [
      "Panelis\\Blog\\Plugins\\BlogPlugin"
    ]
  },
  "require-dev": {
    "laravel/pint": "^1.29"
  }
}
